---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseRaw = import.meta.env.BASE_URL ?? "/";
const baseNoSlash =
  baseRaw === "/" ? "" : baseRaw.endsWith("/") ? baseRaw.slice(0, -1) : baseRaw;
---

<BaseLayout title="Not Found - FIB" description="The requested page does not exist.">
  <section class="rounded-3xl border border-white/10 bg-black/25 p-8 sm:p-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">404</h1>
    <p class="mt-3 text-white/70">
      This page doesn’t exist (yet). Use the navigation above to find what
      you need.
    </p>
    <a
      href={`${baseNoSlash}/`}
      class="fib-focus-ring mt-6 inline-flex items-center justify-center rounded-xl bg-fibGoldDeep px-5 py-3 text-sm font-semibold text-black transition hover:bg-fibGold"
    >
      Back to home
    </a>
  </section>
</BaseLayout>

