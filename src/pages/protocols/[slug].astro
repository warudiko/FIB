---
import { getCollection, getEntryBySlug } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import TocSidebar from "../../components/TocSidebar.astro";

export async function getStaticPaths() {
  const protocols = await getCollection("protocols");

  return protocols.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const slug = Astro.params.slug;
const entry = await getEntryBySlug("protocols", slug);

if (!entry) {
  return Astro.rewrite("/404");
}

const { Content } = await entry.render();
---

<BaseLayout pageTitle={entry.data.title} description={entry.data.short ?? "Protocol details."}>
  <div class="rounded-3xl border border-white/10 bg-black/35 px-5 py-6 shadow-lg shadow-black/40 sm:px-8 sm:py-8 lg:px-10 lg:py-10">
    <SectionHeading
      title={entry.data.title}
      description={entry.data.heroTagline ?? entry.data.short ?? ""}
      accentInitials={false}
    />

    <div class="lg:grid lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-8">
      <TocSidebar targetSelector="#doc" label="Sections" />

      <div class="prose-fib max-w-3xl">
        <article id="doc" class="space-y-4">
          <Content />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>
