---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ProtocolCard from "../../components/ProtocolCard.astro";
import SearchBar from "../../components/SearchBar.astro";

const protocols = (await getCollection("protocols"))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((entry) => ({ ...entry.data, slug: entry.slug }));
---

<BaseLayout pageTitle="Protocols" description="Browse operational protocols.">
  <SectionHeading
    eyebrow="PROTOCOLS"
    title="პროტოკოლები"
    description="სცენარზე დაფუძნებული პროცედურები და კოდური დანიშნულებები."
    accentInitials={false}
  />

  <SearchBar targetId="protocols-grid" placeholder="Search…" ariaLabel="Search protocols" />

  <div id="protocols-grid" class="grid gap-5 md:grid-cols-2">
    {protocols.map((p, index) => (
      <ProtocolCard
        title={p.title}
        short={p.short}
        slug={p.slug}
        heroTagline={p.heroTagline}
        searchText={[p.title, p.short, p.heroTagline, p.slug, ...(p.tags ?? [])].filter(Boolean).join(" • ")}
        revealDelay={index * 70}
      />
    ))}
  </div>
</BaseLayout>
