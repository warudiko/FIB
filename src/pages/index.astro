---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/urls";
import DivisionCard from "../components/DivisionCard.astro";
import ProtocolCard from "../components/ProtocolCard.astro";
import ActionCard from "../components/ActionCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SearchBar from "../components/SearchBar.astro";

const divisions = (await getCollection("divisions"))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((entry) => ({ ...entry.data, slug: entry.slug }));

const protocols = (await getCollection("protocols"))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((entry) => ({ ...entry.data, slug: entry.slug }));

const actions = (await getCollection("actions"))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((entry) => ({ ...entry.data, slug: entry.slug }));

const fibEmblemSrc = withBase(import.meta.env.BASE_URL, "/division-emblems/federal-investigation-bureau.png");
---

<BaseLayout
  title="FIB - Federal Investigation Bureau"
  description="Explore FIB divisions and official public-facing information."
>
  <section class="fib-reveal relative overflow-hidden rounded-3xl border border-white/10 bg-black/25 p-8 pr-32 sm:p-10 sm:pr-44">
    <div class="pointer-events-none absolute inset-0 opacity-90">
      <div class="absolute -top-24 left-10 h-56 w-56 rounded-full bg-fibGold/10 blur-3xl"></div>
      <div class="absolute -bottom-28 right-8 h-72 w-72 rounded-full bg-fibGoldDeep/10 blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(255,255,255,0.08)_1px,transparent_0)] [background-size:26px_26px] opacity-20"></div>
    </div>

    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 right-0 w-56 sm:w-72 overflow-hidden">
      <img
        src={fibEmblemSrc}
        alt=""
        loading="eager"
        decoding="async"
        class="absolute right-0 top-1/2 w-64 sm:w-80 -translate-y-1/2 translate-x-10 opacity-30 blur-[1.5px] saturate-150"
        onerror="this.style.display='none'"
      />
    </div>

    <div class="relative">
      <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
        <span class="fib-accent">F</span>ederal{" "}
        <span class="fib-accent">I</span>nvestigation{" "}
        <span class="fib-accent">B</span>ureau
      </h1>
      <p class="mt-5 max-w-2xl text-white/70">
        არის შიდა სადაზვერვო და საზედამხედველო, ფედერალური იურისდიქციის მქონე
        სამართალდამცავი წინასწარი გამოძიების მთავარი ორგანო. FIB-ის თანამშრომლები
        სამსახურებრივი მოვალეობის შესრულებისას არიან ხელისუფლების წარმომადგენლები და
        იმყოფებიან სახელმწიფოს დაცვის ქვეშ.
      </p>
    </div>
  </section>

  <SearchBar
    scopeSelector="#home-search-scope"
    placeholder="Search…"
    ariaLabel="Search site cards"
  />

  <div id="home-search-scope">
  <section class="mt-10" data-search-section>
    <div class="flex items-start justify-between gap-6">
      <SectionHeading
        eyebrow="DIVISIONS"
        title="დივიზიების მიმოხილვა"
        description="გაეცანით სპეციალიზებულ დივიზიებს და მათ საჯარო პასუხისმგებლობებს."
        accentInitials={false}
      />
    </div>

    <div id="home-divisions-grid" class="grid gap-5 md:grid-cols-2">
      {divisions.map((d, index) => (
        <DivisionCard
          title={d.title}
          short={d.short}
          slug={d.slug}
          heroTagline={d.heroTagline}
          searchText={[d.title, d.short, d.heroTagline, d.slug, ...(d.tags ?? [])].filter(Boolean).join(" • ")}
          revealDelay={index * 70}
        />
      ))}
    </div>
  </section>

  <section class="mt-10" data-search-section>
    <div class="flex items-start justify-between gap-6">
      <SectionHeading
        eyebrow="PROTOCOLS"
        title="ოპერაციული პროტოკოლები"
        description="სწრაფი წვდომა სცენარზე დაფუძნებულ პროცედურებსა და კოდურ დანიშნულებებზე."
        accentInitials={false}
      />
    </div>

    <div id="home-protocols-grid" class="grid gap-5 md:grid-cols-2">
      {protocols.map((p, index) => (
        <ProtocolCard
          title={p.title}
          short={p.short}
          slug={p.slug}
          heroTagline={p.heroTagline}
          searchText={[p.title, p.short, p.heroTagline, p.slug, ...(p.tags ?? [])].filter(Boolean).join(" • ")}
          revealDelay={index * 70}
        />
      ))}
    </div>
  </section>

  <section class="mt-10" data-search-section>
    <div class="flex items-start justify-between gap-6">
      <SectionHeading
        eyebrow="ACTIONS"
        title="გათამაშებები"
        description="გამზადებული ბრძანებები სწრაფი როლური თამაშისთვის."
        accentInitials={false}
      />
    </div>

    <div id="home-actions-grid" class="grid gap-5 md:grid-cols-2">
      {actions.map((a, index) => (
        <ActionCard
          title={a.title}
          short={a.short}
          slug={a.slug}
          heroTagline={a.heroTagline}
          searchText={[a.title, a.short, a.heroTagline, a.slug, ...(a.tags ?? [])].filter(Boolean).join(" • ")}
          revealDelay={index * 70}
        />
      ))}
    </div>
  </section>
  </div>
</BaseLayout>

