---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
---

<BaseLayout
  title="Sources & References - FIB"
  description="Links and references related to FIB informational content."
>
  <SectionHeading
    eyebrow="References"
    title="Sources and public materials"
    description="Add links to official public resources here when you have them."
  />

  <div class="rounded-3xl border border-white/10 bg-black/25 p-8 sm:p-10">
    <div class="text-sm text-white/70">
      This page is intentionally left as a placeholder. Replace with the
      references you want to publish publicly.
    </div>

    <ul class="mt-6 list-disc space-y-2 pl-5 text-sm text-white/70">
      <li>
        <a class="fib-focus-ring text-fibGoldDeep hover:text-white" href="#"
          >Official publication (TBD)</a
        >
      </li>
      <li>
        <a class="fib-focus-ring text-fibGoldDeep hover:text-white" href="#"
          >Public resource portal (TBD)</a
        >
      </li>
    </ul>
  </div>
</BaseLayout>

