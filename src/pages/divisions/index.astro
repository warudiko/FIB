---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import DivisionCard from "../../components/DivisionCard.astro";
import SearchBar from "../../components/SearchBar.astro";
import { cardSearchTextFromEntry } from "../../utils/cardSearchText";

const divisions = (await getCollection("divisions")).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
---

<BaseLayout pageTitle="Divisions" description="Browse all FIB divisions.">
  <SectionHeading
    eyebrow="DEPARTMENTS"
    title="დეპარტამენტები"
    description="გაეცანით დეპარტამენტებს და მათ საჯარო პასუხისმგებლობებს."
    accentInitials={false}
  />

  <SearchBar targetId="divisions-grid" placeholder="Search…" ariaLabel="Search divisions" />

  <div id="divisions-grid" class="grid gap-5 md:grid-cols-2">
    {divisions.map((entry, index) => (
      <DivisionCard
        title={entry.data.title}
        short={entry.data.short}
        slug={entry.slug}
        heroTagline={entry.data.heroTagline}
        searchText={cardSearchTextFromEntry(entry)}
        revealDelay={index * 70}
      />
    ))}
  </div>
</BaseLayout>

