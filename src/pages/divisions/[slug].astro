---
import { getEntryBySlug } from "astro:content";
import { notFound } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";

const slug = Astro.params.slug;
const entry = await getEntryBySlug("divisions", slug);

if (!entry) {
  return notFound();
}
---

<BaseLayout
  title={`${entry.data.title} - FIB`}
  description={entry.data.short ?? "FIB division information."}
>
  <div class="rounded-3xl border border-white/10 bg-black/25 p-8 sm:p-10">
    <SectionHeading
      eyebrow="Division"
      title={entry.data.title}
      description={entry.data.heroTagline ?? entry.data.short ?? ""}
    />

    <div class="prose-fib max-w-3xl">
      <article>
        <entry.render />
      </article>
    </div>
  </div>
</BaseLayout>

