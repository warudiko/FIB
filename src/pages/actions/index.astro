---
import { getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ActionCard from "../../components/ActionCard.astro";
import SearchBar from "../../components/SearchBar.astro";
import { cardSearchTextFromEntry } from "../../utils/cardSearchText";

const actions = (await getCollection("actions")).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
---

<BaseLayout pageTitle="Actions" description="Browse actions (roleplay command sets).">
  <SectionHeading
    eyebrow="ACTIONS"
    title="გათამაშებები"
    description="გამზადებული ბრძანებები სწრაფი როლური თამაშისთვის."
    accentInitials={false}
  />

  <SearchBar targetId="actions-grid" placeholder="Search…" ariaLabel="Search actions" />

  <div id="actions-grid" class="grid gap-5 md:grid-cols-2">
    {actions.map((entry, index) => (
      <ActionCard
        title={entry.data.title}
        short={entry.data.short}
        slug={entry.slug}
        heroTagline={entry.data.heroTagline}
        searchText={cardSearchTextFromEntry(entry)}
        revealDelay={index * 70}
      />
    ))}
  </div>
</BaseLayout>

