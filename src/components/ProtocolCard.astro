---
import { withBase } from "../utils/urls";

const { title, short, slug, heroTagline, revealDelay = 0, searchText } = Astro.props;

const href = withBase(import.meta.env.BASE_URL, `/protocols/${slug}`);
const artSrcPng = withBase(import.meta.env.BASE_URL, `/protocol-art/${slug}.png`);
const artSrcJpg = withBase(import.meta.env.BASE_URL, `/protocol-art/${slug}.jpg`);
const revealStyle = revealDelay ? `transition-delay: ${Number(revealDelay)}ms;` : undefined;
---

<div class="fib-reveal h-full" style={revealStyle} data-search={searchText}>
  <a
    href={href}
    class="fib-card group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-black/35 p-5 shadow-sm"
  >
    <div aria-hidden="true" data-protocol-art class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <img
        src={artSrcPng}
        data-art-fallback={artSrcJpg}
        alt=""
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full scale-105 object-cover object-[82%_center] opacity-70 blur-md saturate-125"
        onerror="if (this.dataset.artFallback) { this.src = this.dataset.artFallback; delete this.dataset.artFallback; return; } this.closest('[data-protocol-art]')?.remove()"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/25 to-black/15"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/88 via-black/55 to-black/28"></div>
    </div>

    <span aria-hidden="true" class="fib-card-glare z-[1]"></span>

    <div class="relative z-[2] flex min-h-0 flex-1 flex-col">
      <h3 class="text-lg font-semibold tracking-tight text-white/90 group-hover:text-white">
        {title}
      </h3>

      {heroTagline ? <p class="mt-4 text-sm text-white/80">{heroTagline}</p> : null}
      {short ? <p class="mt-2 text-sm text-white/65">{short}</p> : null}

      <div class="mt-auto pt-5 flex items-center gap-2 text-sm font-semibold text-fibGoldDeep">
        იხილეთ მეტი
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
      </div>
    </div>
  </a>
</div>

<script>
  // Intentionally empty: tilt script is bound in `DivisionCard.astro` (guarded by `window.__fibCardTiltBound`).
  // This keeps the effect present on pages that render divisions or protocols.
  if (!(window).__fibCardTiltBound) {
    // If a page only renders protocol cards, the guard above would prevent any tilt binding.
    // So we mirror the binding here by importing the same behavior from the global guard.
    window.__fibCardTiltBound = true;

      const resetCard = (card) => {
        card.style.setProperty("--fib-rotate-x", "0deg");
        card.style.setProperty("--fib-rotate-y", "0deg");
        card.style.setProperty("--fib-glare-x", "50%");
        card.style.setProperty("--fib-glare-y", "50%");
      };

      const updateCard = (card, clientX, clientY) => {
        const rect = card.getBoundingClientRect();
        const x = clientX - rect.left;
        const y = clientY - rect.top;
        const px = Math.min(1, Math.max(0, x / rect.width));
        const py = Math.min(1, Math.max(0, y / rect.height));
        const rotateY = (px - 0.5) * 12;
        const rotateX = (0.5 - py) * 10;

        card.style.setProperty("--fib-rotate-x", `${rotateX.toFixed(2)}deg`);
        card.style.setProperty("--fib-rotate-y", `${rotateY.toFixed(2)}deg`);
        card.style.setProperty("--fib-glare-x", `${(px * 100).toFixed(2)}%`);
        card.style.setProperty("--fib-glare-y", `${(py * 100).toFixed(2)}%`);
      };

      const getCardFromTarget = (target) => {
        if (target instanceof Element) return target.closest(".fib-card");
        const parent = target?.parentElement;
        return parent instanceof Element ? parent.closest(".fib-card") : null;
      };

      const getCardFromPoint = (x, y) => {
        const el = typeof document.elementFromPoint === "function" ? document.elementFromPoint(x, y) : null;
        return el instanceof Element ? el.closest(".fib-card") : null;
      };

      let activeCard = null;
      let lastClientX = 0;
      let lastClientY = 0;
      let idleResetTimer = null;

      const onEnter = (event) => {
        activeCard = getCardFromTarget(event.target) ?? getCardFromPoint(event.clientX, event.clientY);
        lastClientX = event.clientX;
        lastClientY = event.clientY;
      };

      const resetActiveIfPointerOutside = () => {
        if (!activeCard) return;
        const el = getCardFromPoint(lastClientX, lastClientY);
        if (!el || el !== activeCard) {
          resetCard(activeCard);
          activeCard = null;
        }
      };

      const scheduleIdleReset = () => {
        if (idleResetTimer) window.clearTimeout(idleResetTimer);
        idleResetTimer = window.setTimeout(() => {
          resetActiveIfPointerOutside();
        }, 90);
      };

      const onMove = (event) => {
        if ("pointerType" in event && event.pointerType && event.pointerType !== "mouse") return;
        const card = activeCard ?? getCardFromTarget(event.target) ?? getCardFromPoint(event.clientX, event.clientY);
        if (!card) return;

        lastClientX = event.clientX;
        lastClientY = event.clientY;

        if (activeCard) {
          const rect = activeCard.getBoundingClientRect();
          const outside =
            event.clientX < rect.left ||
            event.clientX > rect.right ||
            event.clientY < rect.top ||
            event.clientY > rect.bottom;
          if (outside) {
            resetCard(activeCard);
            activeCard = null;
            return;
          }
        }

        updateCard(card, event.clientX, event.clientY);
        scheduleIdleReset();
      };

      const onLeave = (event) => {
        const card = getCardFromTarget(event.target);
        if (!card) return;
        const to = event.relatedTarget;
        if (to instanceof Node && card.contains(to)) return;
        if (activeCard === card) activeCard = null;
        resetCard(card);
      };

      document.addEventListener("pointerover", onEnter, true);
      document.addEventListener("pointermove", onMove, true);
      document.addEventListener("pointerout", onLeave, true);
      document.addEventListener("mouseover", onEnter, true);
      document.addEventListener("mousemove", onMove, true);
      document.addEventListener("mouseout", onLeave, true);

      window.addEventListener("blur", resetActiveIfPointerOutside);
      document.addEventListener("visibilitychange", resetActiveIfPointerOutside);
      window.addEventListener("scroll", resetActiveIfPointerOutside, true);

      document.querySelectorAll(".fib-card").forEach(resetCard);
  }
</script>
