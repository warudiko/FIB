---
const { eyebrow, title, description } = Astro.props;
---

<section class="mb-8">
  {eyebrow ? (
    <p class="mb-2 text-xs font-semibold tracking-widest text-fibGoldDeep uppercase">
      {eyebrow}
    </p>
  ) : null}
  <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">{title}</h2>
  {description ? (
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75">{description}</p>
  ) : null}
</section>

