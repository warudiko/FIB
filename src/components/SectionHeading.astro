---
const { eyebrow, title, description, accentInitials = true } = Astro.props;
const titleWords = typeof title === "string" ? title.split(" ") : [];
---

<section class="mb-8">
  {eyebrow ? (
    <p class="mb-2 text-xs font-semibold tracking-widest text-fibGoldDeep uppercase">
      {eyebrow}
    </p>
  ) : null}
  {title ? (
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      {!accentInitials ? (
        title
      ) : titleWords.length ? (
        titleWords.map((word, index) => (
          <>
            <span class="fib-accent">{word.charAt(0)}</span><span>{word.slice(1)}</span>
            {index < titleWords.length - 1 ? " " : ""}
          </>
        ))
      ) : (
        title
      )}
    </h2>
  ) : null}
  {description ? (
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75">{description}</p>
  ) : null}
</section>

