---
const {
  targetId,
  scopeSelector,
  placeholder = "Search…",
  ariaLabel = "Search",
} = Astro.props as {
  targetId?: string;
  scopeSelector?: string;
  placeholder?: string;
  ariaLabel?: string;
};
---

<div
  class="fib-search fib-reveal"
  data-fib-search
  {...(targetId ? { "data-target": targetId } : {})}
  {...(scopeSelector ? { "data-scope": scopeSelector } : {})}
>
  <div class="fib-search-inputWrap">
    <svg
      class="fib-search-icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      width="16"
      height="16"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7"></circle>
      <path d="M21 21l-4.3-4.3"></path>
    </svg>
    <input
      class="fib-search-input"
      type="search"
      inputmode="search"
      autocomplete="off"
      spellcheck="false"
      aria-label={ariaLabel}
      placeholder={placeholder}
    />
    <button type="button" class="fib-search-clear" aria-label="Clear search" hidden>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        width="16"
        height="16"
        aria-hidden="true"
      >
        <path d="M18 6L6 18"></path>
        <path d="M6 6l12 12"></path>
      </svg>
    </button>
  </div>
  <div class="fib-search-meta" aria-live="polite"></div>
</div>

<script>
  const PENDING_PAGE_SEARCH_KEY = "fib-pending-page-search";

  const shouldPersistSearchForDetailNav = (href) => {
    try {
      const u = new URL(href, window.location.href);
      const p = u.pathname.replace(/\/+$/, "") || "/";
      return /\/divisions\/[^/]+$/.test(p) || /\/protocols\/[^/]+$/.test(p);
    } catch {
      return false;
    }
  };

  const findCardGridSearchInput = (card) => {
    if (card.closest("#home-search-scope")) {
      return document.querySelector('[data-fib-search][data-scope="#home-search-scope"] input');
    }
    const grids = [
      ["#divisions-grid", "divisions-grid"],
      ["#protocols-grid", "protocols-grid"],
    ];
    for (const [gridSel, targetId] of grids) {
      if (card.closest(gridSel)) {
        return document.querySelector(`[data-fib-search][data-target="${targetId}"] input`);
      }
    }
    return null;
  };

  const installDetailSearchHandoff = () => {
    if (typeof window === "undefined") return;
    if (window.__fibDetailSearchHandoff) return;
    window.__fibDetailSearchHandoff = true;

    document.addEventListener(
      "click",
      (e) => {
        if (!(e instanceof MouseEvent)) return;
        if (e.defaultPrevented || e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const t = e.target;
        if (!(t instanceof Element)) return;
        const link = t.closest("a[href]");
        if (!(link instanceof HTMLAnchorElement)) return;
        if (link.target === "_blank" || link.hasAttribute("download")) return;
        const rawHref = link.getAttribute("href") ?? link.href;
        if (!shouldPersistSearchForDetailNav(rawHref)) return;

        const card = link.closest("[data-search]");
        if (!card) return;
        const input = findCardGridSearchInput(card);
        if (!(input instanceof HTMLInputElement)) return;
        const q = (input.value ?? "").trim();
        if (!q) return;
        try {
          sessionStorage.setItem(PENDING_PAGE_SEARCH_KEY, input.value);
        } catch {
          /* ignore */
        }
      },
      true,
    );
  };

  installDetailSearchHandoff();

  const normalize = (value) =>
    String(value ?? "")
      .toLowerCase()
      .replace(/[^\p{L}\p{N}]+/gu, " ")
      .trim()
      .replace(/\s+/g, " ");

  const tokenize = (query) => normalize(query).split(" ").filter(Boolean);

  const computeScore = (haystack, tokens) => {
    if (!tokens.length) return 1;
    let score = 0;
    for (const token of tokens) {
      const idx = haystack.indexOf(token);
      if (idx === -1) return 0;
      score += idx === 0 ? 6 : idx < 8 ? 4 : 2;
    }
    return score;
  };

  const applyFilter = (root, query) => {
    const tokens = tokenize(query);
    const cards = Array.from(root.querySelectorAll("[data-search]"));
    let shown = 0;

    for (const el of cards) {
      const haystack = normalize(el.getAttribute("data-search"));
      const score = computeScore(haystack, tokens);
      const visible = score > 0;
      el.classList.toggle("fib-search-hidden", !visible);
      if (visible) shown += 1;
    }

    const sections = Array.from(root.querySelectorAll("[data-search-section]"));
    if (sections.length) {
      const searching = tokens.length > 0;
      for (const section of sections) {
        const visibleInSection = section.querySelectorAll("[data-search]:not(.fib-search-hidden)").length;
        section.classList.toggle("fib-search-hidden", searching && visibleInSection === 0);
      }
    }

    return { shown, total: cards.length };
  };

  const init = () => {
    document.querySelectorAll("[data-fib-search]").forEach((wrap) => {
      const targetId = wrap.getAttribute("data-target");
      const scopeSelector = wrap.getAttribute("data-scope");
      const input = wrap.querySelector("input");
      const clearBtn = wrap.querySelector("button");
      const meta = wrap.querySelector(".fib-search-meta");
      const root = targetId
        ? document.getElementById(targetId)
        : scopeSelector
          ? document.querySelector(scopeSelector)
          : null;
      if (!(input instanceof HTMLInputElement) || !(clearBtn instanceof HTMLButtonElement) || !meta || !root) return;

      const refresh = () => {
        const value = input.value ?? "";
        clearBtn.hidden = !value.length;
        const { shown, total } = applyFilter(root, value);
        meta.textContent = value.length ? `ნაპოვნია: ${shown} / ${total}` : "";
      };

      input.addEventListener("input", refresh);
      clearBtn.addEventListener("click", () => {
        input.value = "";
        input.focus();
        refresh();
      });

      refresh();
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

