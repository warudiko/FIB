---
const baseRaw = import.meta.env.BASE_URL ?? "/";
const baseNoSlash = baseRaw === "/" ? "" : baseRaw.endsWith("/") ? baseRaw.slice(0, -1) : baseRaw;
const year = new Date().getFullYear();
---

<footer class="mt-14 border-t border-white/5 bg-black/40">
  <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <div class="text-sm text-white/75">
          <span class="fib-accent font-semibold">FIB</span> — Federal Investigation Department
        </div>
        <div class="mt-2 text-xs text-white/50">
          © {year} FIB. All information presented is for demonstration and public reference.
        </div>
        <div class="mt-1 flex items-center gap-2 text-xs text-white/45">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="h-3.5 w-3.5 fib-accent"
            fill="currentColor"
          >
            {/* The Discord glyph is slightly left-heavy at small sizes; nudge for optical centering. */}
            <g transform="translate(0.4 0)">
              <path
                d="M20.317 4.369A19.791 19.791 0 0 0 15.885 3c-.191.328-.403.77-.554 1.116a18.27 18.27 0 0 0-5.487 0A12.64 12.64 0 0 0 9.29 3a19.736 19.736 0 0 0-4.434 1.37C2.05 8.56 1.288 12.646 1.67 16.675a19.9 19.9 0 0 0 5.993 3.031c.485-.667.917-1.37 1.288-2.11a12.955 12.955 0 0 1-2.03-.97c.17-.126.336-.258.497-.396c3.919 1.84 8.18 1.84 12.052 0c.162.138.328.27.498.396a12.9 12.9 0 0 1-2.032.971c.371.739.803 1.442 1.288 2.109a19.875 19.875 0 0 0 5.995-3.03c.478-4.669-.817-8.718-3.906-12.307ZM9.813 14.247c-1.182 0-2.154-1.085-2.154-2.419c0-1.333.953-2.418 2.154-2.418c1.21 0 2.173 1.095 2.154 2.418c0 1.334-.953 2.419-2.154 2.419Zm4.374 0c-1.182 0-2.154-1.085-2.154-2.419c0-1.333.953-2.418 2.154-2.418c1.21 0 2.173 1.095 2.154 2.418c0 1.334-.944 2.419-2.154 2.419Z"
              ></path>
            </g>
          </svg>
          <span class="fib-accent">@warudiko</span>
        </div>
      </div>

      <div class="flex items-center gap-4 text-sm"></div>
    </div>
  </div>
</footer>

