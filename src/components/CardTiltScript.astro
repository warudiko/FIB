<script>
  // Lightweight card tilt/glare effect, delegated from the document.
  // Disabled for reduced motion.
  const prefersReducedMotion =
    typeof window !== "undefined" &&
    typeof window.matchMedia === "function" &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!(window).__fibCardTiltBound && !prefersReducedMotion) {
    window.__fibCardTiltBound = true;

    const resetCard = (card) => {
      card.style.setProperty("--fib-rotate-x", "0deg");
      card.style.setProperty("--fib-rotate-y", "0deg");
      card.style.setProperty("--fib-glare-x", "50%");
      card.style.setProperty("--fib-glare-y", "50%");
    };

    const updateCard = (card, event) => {
      const rect = card.getBoundingClientRect();
      const x = event.clientX - rect.left;
      const y = event.clientY - rect.top;
      const px = Math.min(1, Math.max(0, x / rect.width));
      const py = Math.min(1, Math.max(0, y / rect.height));
      const rotateY = (px - 0.5) * 12;
      const rotateX = (0.5 - py) * 10;

      card.style.setProperty("--fib-rotate-x", `${rotateX.toFixed(2)}deg`);
      card.style.setProperty("--fib-rotate-y", `${rotateY.toFixed(2)}deg`);
      card.style.setProperty("--fib-glare-x", `${(px * 100).toFixed(2)}%`);
      card.style.setProperty("--fib-glare-y", `${(py * 100).toFixed(2)}%`);
    };

    const getCardFromEventTarget = (target) =>
      target instanceof Element ? target.closest(".fib-card") : null;

    let activeCard = null;

    document.addEventListener(
      "pointerover",
      (event) => {
        const card = getCardFromEventTarget(event.target);
        if (!card) return;
        activeCard = card;
      },
      true
    );

    document.addEventListener("pointermove", (event) => {
      const card = activeCard ?? getCardFromEventTarget(event.target);
      if (!card) return;
      updateCard(card, event);
    });

    document.addEventListener(
      "pointerout",
      (event) => {
        const card = getCardFromEventTarget(event.target);
        if (!card) return;
        const to = event.relatedTarget;
        if (to instanceof Node && card.contains(to)) return;
        if (activeCard === card) activeCard = null;
        resetCard(card);
      },
      true
    );

    // Initialize any cards already on the page.
    document.querySelectorAll(".fib-card").forEach(resetCard);
  }
</script>

