---
const { title, short, slug, heroTagline } = Astro.props;
const baseRaw = import.meta.env.BASE_URL ?? "/";
const baseNoSlash = baseRaw === "/" ? "" : baseRaw.endsWith("/") ? baseRaw.slice(0, -1) : baseRaw;

const href = `${baseNoSlash}/divisions/${slug}`;
---

<a
  href={href}
  class="group block rounded-2xl border border-white/10 bg-black/20 p-5 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-white/20 hover:shadow-fibGlow"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="text-xs font-semibold tracking-widest text-fibGoldDeep uppercase">
        Division
      </div>
      <h3 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-white">
        {title}
      </h3>
    </div>

    <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-right">
      <div class="text-xs text-white/60">Section</div>
      <div class="text-sm font-semibold fib-accent">
        {slug.replaceAll("-", " ")}
      </div>
    </div>
  </div>

  {heroTagline ? (
    <p class="mt-4 text-sm text-white/75">{heroTagline}</p>
  ) : null}

  {short ? (
    <p class="mt-3 text-sm text-white/65">{short}</p>
  ) : null}

  <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-fibGoldDeep">
    View details
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
      →
    </span>
  </div>
</a>

